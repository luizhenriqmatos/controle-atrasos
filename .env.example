# Configuração de Segurança
# IMPORTANTE: NÃO faça commit de variáveis sensíveis no repositório
# Use este arquivo como referência e crie um .env.local com valores reais

# Hash da senha admin (nunca a senha em texto plano)
# Gerar em: https://bcrypt-generator.com/ ou usar bcrypt no Node.js
VITE_ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# URL da API (se aplicável)
VITE_API_URL=http://localhost:3000

# Ambiente
VITE_ENVIRONMENT=development

# Tempo de sessão (minutos)
VITE_SESSION_TIMEOUT=30
